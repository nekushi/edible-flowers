// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ImageWithCaption {
  id            String   @id @default(uuid())
  product_title String   @default("no title yet.")
  caption       String   @default("no caption yet.")
  img_url       String
  price         Decimal?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
}

model Orders {
  id       String @id @default(uuid())
  order_id String
  title    String
  caption  String
  quantity Int
  img_url  String

  client_email_request ClientEmailRequest @relation(fields: [order_id], references: [orders_id])
}

model ClientEmailRequest {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  is_read   Boolean  @default(false)
  is_done   Boolean  @default(false)
  orders_id String   @unique
  orders    Orders[]
}
